# =============================================================================
# PROD — облачный сервер (реальные секреты, HTTPS, смена всех CHANGE_ME)
# В .env только секреты и окруженческие значения. Логирование, трейсинг, метрики —
# в backend/config/production.yaml.
# =============================================================================

MODE=prod
DOCKER_NETWORK_NAME=taskflow-prod

# --- MySQL (обязательно сменить) ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=mkk
MYSQL_USER=mkk
MYSQL_PASSWORD=CHANGE_ME_STRONG_USER_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# --- Redis ---
REDIS_ADDR=redis-master-1:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# --- JWT (backend: обязательно сменить) ---
JWT_ACCESS_SECRET=CHANGE_ME_STRONG_JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_JWT_REFRESH_SECRET

# --- Миграции ---
MIGRATIONS_AUTO=true

# --- Backend (образ из registry: latest или sha) ---
BACKEND_IMAGE=ghcr.io/alexander-mandzhiev/taskflow-backend
IMAGE_TAG=latest
BACKEND_PORT=4000

# --- Traefik: Let's Encrypt ---
ACME_EMAIL=admin@yourdomain.com

# --- Observability: Elasticsearch + Kibana (обязательно сменить) ---
ELASTIC_PASSWORD=CHANGE_ME_STRONG_ELASTIC_PASSWORD
KIBANA_SYSTEM_PASSWORD=CHANGE_ME_STRONG_KIBANA_SYSTEM_PASSWORD
KIBANA_ADMIN_USERNAME=kibana_system
KIBANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_KIBANA_ADMIN_PASSWORD
XPACK_SECURITY_ENCRYPTIONKEY=CHANGE_ME_32_CHARS_MIN_ENCRYPTION_KEY!!
XPACK_ENCRYPTEDSAVEDOBJECTS_ENCRYPTIONKEY=CHANGE_ME_32_CHARS_MIN_KEY!!
XPACK_REPORTING_ENCRYPTIONKEY=CHANGE_ME_32_CHARS_MIN_KEY!!
LOGS_DOMAIN=logs.yourdomain.com

# --- Observability: Grafana ---
GRAFANA_ROOT_URL=https://metrics.yourdomain.com
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD
GRAFANA_DOMAIN=metrics.yourdomain.com
GRAFANA_SERVE_FROM_SUB_PATH=false
