# =============================================================================
# DEV — всё в Docker (traefik + db + cache + backend + observability), сеть taskflow-dev
# В .env только секреты и окруженческие значения. Логирование, трейсинг, метрики —
# в backend/config/production.yaml.
# =============================================================================

MODE=dev
DOCKER_NETWORK_NAME=taskflow-dev

# --- MySQL ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=mkk
MYSQL_USER=mkk
MYSQL_PASSWORD=mkk_secret
MYSQL_ROOT_PASSWORD=root_secret

# --- Redis ---
REDIS_ADDR=redis-master-1:6379
REDIS_PASSWORD=redis_secret

# --- Миграции ---
MIGRATIONS_AUTO=true

# --- Backend (образ собирается через docker-compose.dev.yml) ---
BACKEND_IMAGE=ghcr.io/alexander-mandzhiev/taskflow-backend
IMAGE_TAG=dev
BACKEND_PORT=4000

# --- Observability: Elasticsearch + Kibana ---
ELASTIC_PASSWORD=elastic_dev_secret
KIBANA_SYSTEM_PASSWORD=kibana_system_dev
KIBANA_ADMIN_USERNAME=kibana_system
KIBANA_ADMIN_PASSWORD=kibana_dev_secret
XPACK_SECURITY_ENCRYPTIONKEY=dev_min_32_chars_encryption_key!!
XPACK_ENCRYPTEDSAVEDOBJECTS_ENCRYPTIONKEY=dev_min_32_chars_encryption_key!!
XPACK_REPORTING_ENCRYPTIONKEY=dev_min_32_chars_encryption_key!!
LOGS_DOMAIN=logs.localhost

# --- Observability: Grafana ---
GRAFANA_ROOT_URL=http://grafana.localhost
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_DOMAIN=grafana.localhost
GRAFANA_SERVE_FROM_SUB_PATH=false

# --- OTEL (compose) ---
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
