# =============================================================================
# TEST — окружение для интеграционных тестов (task compose:up:database, compose:up:cache с MODE=test)
# Отдельные порт MySQL (3307), сеть taskflow-test и БД testdb, чтобы не пересекаться с local/dev.
# =============================================================================

MODE=test
DOCKER_NETWORK_NAME=taskflow-test

# --- MySQL (compose database) ---
MYSQL_ROOT_PASSWORD=root_test_secret
MYSQL_DATABASE=testdb
MYSQL_USER=testuser
MYSQL_PASSWORD=testpass
MYSQL_PORT=3307

# --- Redis (compose cache) ---
REDIS_ADDR=redis-master-1:6379
REDIS_PASSWORD=test_redis_secret

# --- Миграции (при запуске backend против тестовой инфры) ---
MIGRATIONS_AUTO=true
