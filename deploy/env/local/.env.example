# =============================================================================
# LOCAL — только для compose (task compose:local:up)
# Секреты для backend при запуске на хосте лежат в backend/config/local.yaml (дефолт).
# Здесь — переменные для контейнеров: MySQL, Redis, observability (otel, logs, grafana).
# =============================================================================

MODE=local
DOCKER_NETWORK_NAME=taskflow-local

# --- MySQL (compose database) ---
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=mkk
MYSQL_USER=mkk
MYSQL_PASSWORD=mkk_secret
MYSQL_PORT=3306

# --- Redis (compose cache) ---
REDIS_ADDR=redis-master-1:6379
REDIS_PASSWORD=redis_secret

# --- Миграции (если поднимаете backend в контейнере) ---
MIGRATIONS_AUTO=true

# --- Backend в контейнере (опционально) ---
# BACKEND_IMAGE=ghcr.io/alexander-mandzhiev/taskflow-backend
# IMAGE_TAG=local
# BACKEND_PORT=4000

# --- Observability stack (compose: otel, metrics, tracing, logs) ---
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

ELASTIC_PASSWORD=elastic_secret
KIBANA_SYSTEM_PASSWORD=kibana_system_secret
KIBANA_ADMIN_USERNAME=kibana_system
KIBANA_ADMIN_PASSWORD=kibana_secret
XPACK_SECURITY_ENCRYPTIONKEY=min_32_chars_encryption_key_here!!
XPACK_ENCRYPTEDSAVEDOBJECTS_ENCRYPTIONKEY=min_32_chars_encryption_key_here!!
XPACK_REPORTING_ENCRYPTIONKEY=min_32_chars_encryption_key_here!!
LOGS_DOMAIN=logs.localhost

GRAFANA_ROOT_URL=http://grafana.localhost
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_DOMAIN=grafana.localhost
GRAFANA_SERVE_FROM_SUB_PATH=false
